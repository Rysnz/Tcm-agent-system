# =============================================================================
# 中医智能问诊系统 - 环境配置示例
# 复制本文件为 .env 并填写真实配置值
# =============================================================================

# -----------------------------------------------------------------------------
# Django 基础配置
# -----------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_generate_with_python_-c_secrets.token_urlsafe_50
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# 数据库配置（PostgreSQL + pgvector）
# -----------------------------------------------------------------------------
POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE_NAME=tcm_agent_db
POSTGRESQL_USER_NAME=postgres
POSTGRESQL_PASSWORD=your_postgres_password_here

# -----------------------------------------------------------------------------
# Redis 配置（用于 Celery 任务队列和会话缓存）
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
DJANGO_CACHE_LOCATION=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# LLM 接入配置（OpenAI 兼容接口）
# 支持：Qwen/ChatGLM/DeepSeek/OpenAI/本地 Ollama
# -----------------------------------------------------------------------------

# --- DeepSeek（推荐，性价比高）---
LLM_MODEL=deepseek-chat
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1

# --- Qwen（阿里云）---
# LLM_MODEL=qwen-max
# LLM_API_KEY=your_dashscope_api_key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- ChatGLM（智谱 AI）---
# LLM_MODEL=glm-4
# LLM_API_KEY=your_zhipuai_api_key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# --- OpenAI ---
# LLM_MODEL=gpt-4o
# LLM_API_KEY=your_openai_api_key
# LLM_BASE_URL=https://api.openai.com/v1

# --- 本地 Ollama（无需 API Key）---
# LLM_MODEL=qwen2.5:7b
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1

# -----------------------------------------------------------------------------
# 嵌入模型配置
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# 使用本地模型路径（可选，避免每次下载）
# LOCAL_EMBEDDING_MODEL_PATH=/path/to/local/bge-large-zh-v1.5

# -----------------------------------------------------------------------------
# 向量数据库配置
# -----------------------------------------------------------------------------
VECTOR_DB_TYPE=pgvector

# -----------------------------------------------------------------------------
# Hugging Face 镜像配置（国内加速）
# -----------------------------------------------------------------------------
HF_ENDPOINT=https://hf-mirror.com

# -----------------------------------------------------------------------------
# 多智能体配置
# -----------------------------------------------------------------------------
# 最大追问轮数（防止无限循环）
AGENT_MAX_INQUIRY_ROUNDS=5
# 辨证置信度阈值（低于此值继续追问）
AGENT_SYNDROME_MIN_CONFIDENCE=0.4
# 是否启用流式输出
AGENT_ENABLE_STREAMING=true

# -----------------------------------------------------------------------------
# 安全配置
# -----------------------------------------------------------------------------
# 高危关键词文件路径（可选，默认使用内置列表）
# SAFETY_KEYWORDS_FILE=/path/to/safety_keywords.json

# -----------------------------------------------------------------------------
# 可观测性配置（Langfuse/LangSmith，可选）
# -----------------------------------------------------------------------------
# LANGCHAIN_API_KEY=your_langchain_api_key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=tcm-agent-system

# -----------------------------------------------------------------------------
# 文件存储配置
# -----------------------------------------------------------------------------
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
